```bash
curl -s -X POST "https://api.indexnow.org/IndexNow" \
  -H "Content-Type: application/json" \
  -d 
"{\"urlList\":[\"https://www.daybydayconsulting.com/blog/SLUG\"],\"key\":\"7de9e
111be6418906030e2ec7be8cb62\",\"host\":\"daybydayconsulting.com\"}"
