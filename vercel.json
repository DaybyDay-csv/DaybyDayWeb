{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "daybydayconsulting.com" }],
      "destination": "https://www.daybydayconsulting.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [{ "source": "/((?!.*\\.).*)", "destination": "/index.html" }]
}
